# $ cpanm --local-lib=~/perl5 --no-test Module::Some
# $ perl -V
#perl local::lib
eval "$(perl -I$HOME/perl5/lib/perl5 -Mlocal::lib)"

function createrandomwavfile() {
    loop=$1
    if [ "$#" -ne 1 ]; then
        loop=1
    fi
    for i in `seq 1 $loop`
    do
        randomseconds=`awk "BEGIN{srand();print 30+int(rand()*10000)%570}"`
        randomwhitenoise=`awk "BEGIN{srand();print 30+int(rand()*10000)%570}"`
        outputfile=`cat /dev/urandom | base64 | fold -w 30 | head -n 1 | sed -e "s/[^a-zA-Z0-9]//g"`.wav
        sox -q -V -r 48000 -n -b 16 -c 2 $outputfile synth $randomseconds whitenoise $randomwhitenoise vol -10dB
    done    
}

function createrandomwavfilehires() {
    loop=$1
    if [ "$#" -ne 1 ]; then
        loop=1
    fi
    for i in `seq 1 $loop`
    do
        randomseconds=`awk "BEGIN{srand();print 30+int(rand()*10000)%570}"`
        randomwhitenoise=`awk "BEGIN{srand();print 30+int(rand()*10000)%570}"`
        outputfile=`cat /dev/urandom | base64 | fold -w 30 | head -n 1 | sed -e "s/[^a-zA-Z0-9]//g"`.wav
        sox -q -V -r 96000 -n -b 24 -c 2 hires_$outputfile synth $randomseconds whitenoise $randomwhitenoise vol -10dB
    done    
}

source <(fzf --zsh)
