# ブランチ名を引数で指定
go_genapi () { go get github.com/wano/tunecorejapan_openapi/src/backend/openapi_golang@$1 }


# my tools
alias cdtools="cd ~/tools"
# random wav
alias random_wav="python3 ~/tools/random_wav.py"
alias random_hires="python3 ~/tools/random_hires.py"

# TCJ Local Dev
# Aliases
alias dball="mysql -uroot -h 127.0.0.1 -P 3307 -p tunecorejapan -A -ppassword --local-infile=1"

# golang
alias tcj-go-admin-err="docker exec tcj-go-server tail -f /var/log/tunecorejapan_go/admin/error/current"
alias tcj-go-site-err="docker exec tcj-go-server tail -f /var/log/tunecorejapan_go/site/error/current"
alias tcj-go-linkcore-err="docker exec tcj-go-server tail -f /var/log/tunecorejapan_go/linkcore/error/current"
alias tcj-go-exec="docker exec -it tcj-go-server bash"

# perl
alias tcj-ap-admin-err="docker exec tcj-ap-server tail -f /var/log/tunecorejapan/admin/error/current"
alias tcj-ap-site-err="docker exec tcj-ap-server tail -f /var/log/tunecorejapan/site/error/current"
alias tcj-ap-exec="docker exec -it tcj-ap-server bash"

# ddb
AWS_PROFILE_FOR_DYNAMO="fake-for-dynamo"
alias ddb="aws dynamodb --profile=$AWS_PROFILE_FOR_DYNAMO $1 --table-name $2 --endpoint-url http://localhost:1400"

